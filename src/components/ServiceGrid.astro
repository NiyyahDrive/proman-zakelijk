---
import { services } from '../data/services.ts';
---

<section class="section bg-proman-cream">
  <div class="container-app">
    <div class="max-w-3xl mb-10 md:mb-12">
      <span class="eyebrow text-proman-orange">Diensten</span>
      <h2 class="heading-lg mt-3 mb-4 text-balance">
        Concrete antwoorden op concrete HR-vragen
      </h2>
      <p class="lead text-balance">
        Van urgent uitzendpersoneel tot discrete executive search. Elke dienst geleverd door het merk dat er gespecialiseerd in is.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
      {services.map(s => (
        <a
          href={`/diensten/${s.slug}/`}
          class="card card-padding hover:border-proman-orange transition-colors group"
        >
          <div class="text-3xl mb-3" aria-hidden="true">{s.icon}</div>
          <h3 class="font-bold text-lg md:text-xl mb-2 group-hover:text-proman-orange transition-colors">{s.name}</h3>
          <p class="text-sm text-proman-navy/70 leading-relaxed mb-4">
            {s.pitch.split('.')[0]}.
          </p>
          <div class="text-sm font-semibold text-proman-orange flex items-center gap-1 group-hover:gap-2 transition-all">
            Meer over {s.name.toLowerCase()}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
