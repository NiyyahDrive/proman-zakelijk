---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  variant?: 'navy' | 'cream' | 'white';
  /** Brand-color tint, overrides variant if set */
  brandColor?: 'jobs' | 'home' | 'care' | 'ascento' | 'winsearch' | 'amplo';
  /** Optionele breadcrumbs */
  breadcrumbs?: { name: string; url: string }[];
}

const {
  eyebrow,
  title,
  subtitle,
  variant = 'navy',
  brandColor,
  breadcrumbs,
} = Astro.props;

const brandGradient: Record<string, string> = {
  jobs: 'from-brand-jobs-from to-brand-jobs-to',
  home: 'from-brand-home-from to-brand-home-to',
  care: 'from-brand-care-from to-brand-care-to',
  ascento: 'from-brand-ascento-from to-brand-ascento-to',
  winsearch: 'from-brand-winsearch-from to-brand-winsearch-to',
  amplo: 'from-brand-amplo-from to-brand-amplo-to',
};

const isNavy = variant === 'navy' && !brandColor;
const isCream = variant === 'cream' && !brandColor;
const isWhite = variant === 'white' && !brandColor;
const isBrand = !!brandColor;
---

<section class:list={[
  'relative overflow-hidden',
  isNavy && 'bg-gradient-to-br from-proman-navy via-proman-navy to-proman-navy-dark text-white',
  isCream && 'bg-proman-cream text-proman-navy',
  isWhite && 'bg-white text-proman-navy',
  isBrand && `bg-gradient-to-br ${brandGradient[brandColor!]} text-white`,
]}>
  {(isNavy || isBrand) && (
    <>
      <div class="absolute -top-20 -right-20 w-96 h-96 bg-white/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-white/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
    </>
  )}
  <div class="container-app py-12 md:py-20 lg:py-24 relative">
    {breadcrumbs && (
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class:list={[
          'flex items-center gap-2 text-xs flex-wrap',
          (isNavy || isBrand) ? 'text-white/60' : 'text-proman-navy/50'
        ]}>
          {breadcrumbs.map((bc, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && <span aria-hidden="true">›</span>}
              {i < breadcrumbs.length - 1 ? (
                <a href={bc.url} class={(isNavy || isBrand) ? 'hover:text-white' : 'hover:text-proman-navy'}>{bc.name}</a>
              ) : (
                <span class={(isNavy || isBrand) ? 'text-white/90' : 'text-proman-navy/80'}>{bc.name}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}
    {eyebrow && (
      <span class:list={[
        'eyebrow inline-block mb-4',
        (isNavy || isBrand) ? 'text-white/80' : 'text-proman-orange'
      ]}>{eyebrow}</span>
    )}
    <h1 class="heading-xl mb-4 max-w-4xl text-balance">{title}</h1>
    {subtitle && (
      <p class:list={[
        'lead max-w-3xl text-balance',
        (isNavy || isBrand) ? 'text-white/85' : 'text-proman-navy/75'
      ]}>{subtitle}</p>
    )}
    <slot />
  </div>
</section>
