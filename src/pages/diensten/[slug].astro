---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import { services, getService } from '../../data/services.ts';
import { brands } from '../../data/brands.ts';
import { sectors } from '../../data/sectors.ts';
import { faqSchema, breadcrumbSchema, serviceSchema } from '../../utils/seo.ts';

export function getStaticPaths() {
  return services.map(s => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = getService(slug!)!;
const linkedBrands = brands.filter(b => service.brands.includes(b.slug));
const linkedSectors = sectors.filter(s => service.sectors.includes(s.slug));

const breadcrumbs = [
  { name: 'Home', url: 'https://zakelijk.proman.be/' },
  { name: 'Diensten', url: 'https://zakelijk.proman.be/diensten/' },
  { name: service.name, url: `https://zakelijk.proman.be/diensten/${service.slug}/` },
];
---

<Base
  title={service.h1}
  description={service.metaDescription}
  schema={[
    serviceSchema({ name: service.name, description: service.metaDescription }),
    faqSchema(service.faqs),
    breadcrumbSchema(breadcrumbs),
  ]}
>
  <PageHero
    eyebrow={service.icon + ' Dienst'}
    title={service.h1}
    subtitle={service.pitch}
    breadcrumbs={breadcrumbs}
  >
    <div class="flex flex-col sm:flex-row gap-3 mt-8">
      <a href="/offerte/" class="btn-primary btn-large">
        Vraag een offerte voor {service.name.toLowerCase()}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
      <a href="tel:+3221234567" class="border-2 border-white/30 hover:border-white text-white font-semibold px-6 py-4 rounded-lg transition-colors text-center">
        Bel direct: 02 123 45 67
      </a>
    </div>
  </PageHero>

  <!-- Voor wie -->
  <section class="section bg-white">
    <div class="container-app grid lg:grid-cols-3 gap-10">
      <div class="lg:col-span-1">
        <span class="eyebrow text-proman-orange">Voor wie</span>
        <h2 class="heading-md mt-3 text-balance">Wanneer kies je voor {service.name.toLowerCase()}?</h2>
      </div>
      <div class="lg:col-span-2">
        <p class="text-lg text-proman-navy/85 leading-relaxed">{service.audience}</p>
      </div>
    </div>
  </section>

  <!-- Voordelen -->
  <section class="section bg-proman-cream">
    <div class="container-app">
      <div class="max-w-3xl mb-12">
        <span class="eyebrow text-proman-orange">Voordelen</span>
        <h2 class="heading-md mt-3 mb-4 text-balance">Drie redenen om voor {service.name} via PROMAN te kiezen</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {service.benefits.map((b, i) => (
          <div class="card card-padding">
            <div class="w-10 h-10 rounded-full bg-proman-orange text-white font-extrabold flex items-center justify-center mb-4">{i + 1}</div>
            <h3 class="font-bold text-lg mb-2">{b.title}</h3>
            <p class="text-sm text-proman-navy/75 leading-relaxed">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section bg-proman-navy text-white">
    <div class="container-app">
      <div class="max-w-3xl mb-12">
        <span class="eyebrow text-proman-orange-light">Hoe het werkt</span>
        <h2 class="heading-md mt-3 mb-4 text-balance">Het proces voor {service.name.toLowerCase()}</h2>
      </div>
      <ol class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {service.process.map(p => (
          <li>
            <div class="text-5xl font-extrabold text-proman-orange-light/30 mb-2">{p.step.toString().padStart(2, '0')}</div>
            <h3 class="font-bold text-lg mb-2">{p.title}</h3>
            <p class="text-sm text-white/75 leading-relaxed">{p.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Welke merken leveren dit -->
  {linkedBrands.length > 0 && (
    <section class="section bg-white">
      <div class="container-app">
        <div class="max-w-3xl mb-10">
          <span class="eyebrow text-proman-orange">Wij leveren via</span>
          <h2 class="heading-md mt-3 mb-4 text-balance">Welke merken leveren {service.name.toLowerCase()}?</h2>
          <p class="lead text-balance">Deze dienst wordt geleverd door {linkedBrands.length} van onze merken, elk met een eigen specialisatie.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
          {linkedBrands.map(b => (
            <a href={`/merken/${b.slug}/`} class="card card-padding hover:border-proman-orange transition-colors group">
              <h3 class="font-bold text-lg mb-2 group-hover:text-proman-orange transition-colors">{b.name}</h3>
              <p class="text-sm text-proman-navy/70 leading-relaxed mb-4">{b.tagline}</p>
              <div class="text-sm font-semibold text-proman-orange flex items-center gap-1 group-hover:gap-2 transition-all">
                Ontdek {b.name} →
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Sectoren waar deze dienst gevraagd wordt -->
  {linkedSectors.length > 0 && (
    <section class="section bg-proman-cream">
      <div class="container-app">
        <div class="max-w-3xl mb-8">
          <span class="eyebrow text-proman-orange">Sectoren</span>
          <h2 class="heading-md mt-3 mb-4 text-balance">In welke sectoren leveren we {service.name.toLowerCase()}?</h2>
        </div>
        <div class="flex flex-wrap gap-3">
          {linkedSectors.map(s => (
            <a href={`/sectoren/${s.slug}/`} class="inline-flex items-center gap-2 bg-white border border-proman-navy/15 hover:border-proman-orange rounded-full px-5 py-2.5 font-semibold text-sm transition-colors">
              <span>{s.icon}</span>
              {s.name}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <FAQ
    title={`Veelgestelde vragen over ${service.name.toLowerCase()}`}
    faqs={service.faqs}
  />
  <CTASection
    title={`Klaar voor ${service.name.toLowerCase()} via PROMAN?`}
    subtitle="Vraag offerte op maat. Lokale consulent contacteert je binnen 1 werkdag."
  />
</Base>
