---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { breadcrumbSchema } from '../utils/seo.ts';

const breadcrumbs = [
  { name: 'Home', url: 'https://zakelijk.proman.be/' },
  { name: 'Contact', url: 'https://zakelijk.proman.be/contact/' },
];
---

<Base
  title="Contact — PROMAN Zakelijk"
  description="Neem contact op met PROMAN Zakelijk: telefoon, e-mail of via lokaal kantoor. Snelle aanvraag voor uitzend, werving, payroll, executive search."
  schema={[breadcrumbSchema(breadcrumbs)]}
>
  <PageHero
    eyebrow="Contact"
    title="Spreek direct met ons"
    subtitle="Geen ticket-systeem, geen call-center. Bel of mail rechtstreeks naar de juiste consulent of vraag een vrijblijvend gesprek aan."
    breadcrumbs={breadcrumbs}
  />

  <section class="section bg-white">
    <div class="container-app">
      <div class="grid md:grid-cols-3 gap-6 mb-10">
        <a href="/offerte/" class="card card-padding hover:border-proman-orange transition-colors group block">
          <div class="text-3xl mb-3">📋</div>
          <h2 class="font-bold text-lg mb-2 group-hover:text-proman-orange">Offerte aanvragen</h2>
          <p class="text-sm text-proman-navy/70 leading-relaxed">Concrete vraag voor uitzend, werving, payroll of executive search? Vraag offerte op maat — antwoord binnen 1 werkdag.</p>
        </a>
        <a href="tel:+3221234567" class="card card-padding hover:border-proman-orange transition-colors group block">
          <div class="text-3xl mb-3">📞</div>
          <h2 class="font-bold text-lg mb-2 group-hover:text-proman-orange">Telefoon</h2>
          <p class="text-sm text-proman-navy/70 leading-relaxed mb-3">Liever direct praten? Werkdagen 8u-18u, zaterdag 9u-13u.</p>
          <div class="text-2xl font-extrabold text-proman-navy">02 123 45 67</div>
        </a>
        <a href="mailto:zakelijk@proman.be" class="card card-padding hover:border-proman-orange transition-colors group block">
          <div class="text-3xl mb-3">✉️</div>
          <h2 class="font-bold text-lg mb-2 group-hover:text-proman-orange">E-mail</h2>
          <p class="text-sm text-proman-navy/70 leading-relaxed mb-3">Voor algemene vragen, partnerschappen of pers.</p>
          <div class="font-bold text-proman-navy">zakelijk@proman.be</div>
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="card card-padding md:col-span-1">
          <div class="text-xs uppercase tracking-widest text-proman-orange font-bold mb-3">Hoofdkantoor</div>
          <p class="text-sm leading-relaxed">
            <strong>PROMAN Belgium</strong><br/>
            Tervurenlaan 100<br/>
            1040 Brussel<br/>
            BE 0123.456.789
          </p>
        </div>
        <div class="card card-padding md:col-span-2 bg-proman-cream">
          <div class="text-xs uppercase tracking-widest text-proman-orange font-bold mb-3">Lokaal kantoor zoeken</div>
          <p class="text-sm text-proman-navy/85 leading-relaxed mb-4">
            We hebben 170+ kantoren verspreid over België. Voor concrete vragen ben je vaak het beste geholpen bij het kantoor in jouw regio.
          </p>
          <a href="/regios/" class="inline-flex items-center gap-2 font-semibold text-proman-orange hover:underline">
            Vind kantoor in mijn regio →
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
